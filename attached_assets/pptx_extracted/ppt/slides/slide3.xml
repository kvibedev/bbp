0000000" pitchFamily="2" charset="2"/><a:buChar char="Ø"/></a:pPr><a:r><a:rPr lang="en-US" sz="1100" dirty="0"><a:latin typeface="Raleway Medium" pitchFamily="2" charset="0"/><a:cs typeface="Calibri"/></a:rPr><a:t>Conduct annual market checks to ensure long-term competitiveness and fiduciary accountability.</a:t></a:r><a:endParaRPr lang="en-US" sz="1050" dirty="0"><a:latin typeface="Raleway Medium" pitchFamily="2" charset="0"/><a:cs typeface="Calibri"/></a:endParaRPr></a:p><a:p><a:pPr rtl="0"><a:lnSpc><a:spcPct val="150000"/></a:lnSpc><a:spcBef><a:spcPts val="600"/></a:spcBef><a:buClr><a:schemeClr val="dk1"/></a:buClr><a:buSzPts val="1100"/></a:pPr><a:r><a:rPr lang="en-US" sz="1200" dirty="0"><a:latin typeface="Raleway Medium" pitchFamily="2" charset="0"/></a:rPr><a:t>Together, </a:t></a:r><a:r><a:rPr lang="en-US" sz="1200" dirty="0" err="1"><a:latin typeface="Raleway Medium" pitchFamily="2" charset="0"/></a:rPr><a:t>BenefitsBridge</a:t></a:r><a:r><a:rPr lang="en-US" sz="1200" dirty="0"><a:latin typeface="Raleway Medium" pitchFamily="2" charset="0"/></a:rPr><a:t> Partners, and Ringmaster bring a fully independent, best-in-class model that supports the client’s fiduciary obligations and financial stewardship. With the increasing national focus on prescription drug program oversight — including recent litigation targeting employers for inadequate PBM monitoring — this partnership provides a compliant, transparent, and results-oriented solution.</a:t></a:r></a:p></p:txBody></p:sp><p:cxnSp><p:nvCxnSpPr><p:cNvPr id="21" name="Straight Connector 20"><a:extLst><a:ext uri="{FF2B5EF4-FFF2-40B4-BE49-F238E27FC236}"><a16:creationId xmlns:a16="http://schemas.microsoft.com/office/drawing/2014/main" id="{73589B5F-F46A-72C7-EDF8-8E6E8D7B4093}"/></a:ext></a:extLst></p:cNvPr><p:cNvCxnSpPr><a:cxnSpLocks/></p:cNvCxnSpPr><p:nvPr/></p:nvCxnSpPr><p:spPr><a:xfrm><a:off x="6248400" y="657225"/><a:ext cx="781050" cy="0"/></a:xfrm><a:prstGeom prst="line"><a:avLst/></a:prstGeom><a:ln><a:solidF